---
import { vIconsFile } from '../../public/js/index.js';
const {vIconName, vH3Text} = Astro.props;
---
<h3>
  <svg aria-hidden="true">
    <use href={`${vIconsFile}${vIconName}`} />
  </svg>
  {vH3Text}
</h3>

<style>

  h3 {
    display: flex;
    align-items: center;
    font-size: 2.5rem;
    font-family: var(--vRubikSemiBold);
    margin-bottom: 4rem;
    @media ( width <= 400px ) {
      font-size: 2rem;
    }
    
    & svg {
      --vSize: 3.5rem;
      width: var(--vSize);
      height: var(--vSize);
      margin-right: 1rem;
      stroke: var(--vFontColor);
      stroke-width: 2;
      @media ( width <= 400px ) {
        width: calc(var(--vSize) - .5rem);
        height: calc(var(--vSize) - .5rem);
      }
    }
    
  }

</style>