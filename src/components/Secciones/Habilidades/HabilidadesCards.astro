---
import { vIconsFile } from '../../../../public/js/index.js';
import JSONHabilidades from "../../../../public/js/JSONHabilidades.json";
---

{JSONHabilidades.map((item) => {
  return (
    <div class="cHabilidadCard">
      <div class="cHabiIcono">
        <svg aria-hidden="true">
          <use href={`${vIconsFile}${item.jsonIcono}`}></use>
        </svg>
      </div>
      <h3 class="cHabiNombre">{item.jsonArea}</h3>
      <p class="cHabiDetalles">{item.jsonSoftwares}</p>
    </div>
  );
})}

<style>

  .cHabilidadCard {
    border: 5px solid  var(--vHabColorHR1);
    background-color: var(--vHabColorHR2);
    color: var(--vHabColorHR1);
    box-shadow: var(--vHabColorHR3, 1) 0px 0px 3px 3px;
    border-radius: 2rem;
    width: 19rem;
    height: 22rem;

    & .cHabiIcono {
      height: 25%;
      display: flex;
      justify-content: center;

      & svg {
        --vSise: 4rem;
        width: var(--vSise);
        height: var(--vSise);
        margin-top: 1rem;
        fill: var(--vHabColorHR1);
        stroke: var(--vHabColorHR1);
        stroke-width: 2.5;
      }
    }
    & .cHabiNombre {
      height: 40%;
      font-family: var(--vAardvarkCafe);
      font-weight: 500;
      font-size: 32px;
      text-shadow: 1px 1px #FFFFFF;
      display: flex;
      justify-content: center;
      align-items: center;
    }
    & .cHabiDetalles {
      height: 35%;
      text-align: center;
      font-family: var(--vFrutiger);
      font-size: 20px;
      font-weight: bold;
      padding: 0 1rem;
      line-height: 1.8rem;
    }
  }

</style>