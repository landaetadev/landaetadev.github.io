---
import JSONProyectos from "../../../../public/js/JSONProjectos.json";
import {vProjectsFolder} from '../../../../public/js/index';
import BtnCerrar from '../../Botones/btnCerrar.astro';
let letVideoFolder = "https://filedn.eu/lUfpa3BpLa45XCcSIQyWRHF/WWW/Portfolio/FilesProjects/"
---

<script >
  const btnCerrar = document.querySelectorAll('.cBtnClose');
  
  btnCerrar.forEach((btnCerrar) => {
    btnCerrar.addEventListener('click', () => {
      const vContainer = btnCerrar.closest('.cProjectContainer');
      funcPauseVideo();
      vContainer?.classList.remove('cShowContainer');
      document.body.classList.toggle("noScroll");
    });
  });

  function funcPauseVideo() {
      const vVideo = document.querySelectorAll<HTMLVideoElement>('.cVideo');
      vVideo.forEach(video => {
        video.pause();
        video.currentTime = 0;
      });
  }
</script>

{JSONProyectos.map((item) => {
  return (
    <div class="cProjectContainer">
      <BtnCerrar />
      <div class="cProject">
        <h3 class="cProjectTitle">{item.jsonTitle}</h3>
        <video controls preload="none" class="cVideo" 
        poster={`${vProjectsFolder}${item.jsonImgScreen}Poster.avif`}>
          <source src={`${letVideoFolder}${item.jsonFileShow}.webm`} type="video/webm" />
          <source src={`${letVideoFolder}${item.jsonFileShow}.mp4`} type="video/mp4" />
        </video>
        <p class="cDescript">{item.jsonDescript}</p>
      </div>
    </div>
  )
})}

<style>
  .cProjectContainer {
    background-image: image-set(
      url("/assets/images/backgrounds/001.avif") type("image/avif"),
      url("/assets/images/backgrounds/001.webp") type("image/webp")
    );
    position: fixed;
    top: 0;
    left: 100%;
    width: 100%;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    z-index: 3;
    transition: all .5s ease-in-out;

    & .cProject{
      width: 100%;
      max-width: var(--vMaxWidthContent);
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;


      & .cProjectTitle{
        font-family: var(--vRubikSemiBold);
        font-size: 28px;
        text-align: center;
        padding-bottom: 1rem;
      }

      & video {
        background-color: black;
        width: 100%;
        max-width: 1280px;
        aspect-ratio: 16 / 9;
        display: block;
      }

      & .cDescript{
        max-width: 1000px;
        font-family: var(--vRubikRegular);
        font-size: 20px;
        padding: 2rem .5rem 0 .5rem;
        line-height: 1.5;
      }
    }

    
  }
  .cShowContainer {
    left: 0%;
    transition: all .5s ease-in-out;
  }
</style>