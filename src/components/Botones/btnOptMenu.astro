---
import { vIconsFile } from '../../../public/js/index.js';
const { vIcoBtn, vText, vHref, vTarget="" } = Astro.props;
---

<script>
  const vBtnOptMenu = document.querySelectorAll(".cBtnOptMenu");
  const vMenuNav = document.querySelector(".cMenuNav")
  vBtnOptMenu.forEach(btn => {
    btn.addEventListener("click", () => {
      vMenuNav?.classList.toggle("activo");
      document.documentElement.style.overflowY = "visible";
      document.body.classList.remove ('noScroll');
    });
  });

</script>

  <a href={vHref} class="cBtnOptMenu" target={vTarget} title={vText}>
    <svg aria-hidden="true">
      <use href={`${vIconsFile}${vIcoBtn}`}>
    </svg>
    {vText}
  </a>

<style>

.cBtnOptMenu {
  width: 9rem;
  --vheight: 3rem;
  height: var(--vheight);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3px solid var(--vBtnsCan1);
  border-radius: .75rem;
  background-color: var(--vBtnsCan2);
  color: var(--vBtnsCan1);
  font-family: var(--vRubikRegular);
  font-size: 16px;
  font-weight: 900;
  @media (width <= 1200px) {
    height: calc(var(--vheight) + 2rem);
    width: 100%;
    border-radius: 0;
    font-size: 24px;
  }
  @media (width <= 600px) {
    height: calc(var(--vheight) + 1rem);
    font-size: 20px;
  }
  @media (width <= 400px) {
    height: calc(var(--vheight) + 0.5rem);
  }

  &:hover {
    background-color: var(--vBtnsCanHover);
    transition: transform 0.5s ease-in-out;
    transform: scale(1.1);
  }


  & svg {
    --vSize: 2rem;
    width: var(--vSize);
    height: var(--vSize);
    stroke: var(--vBtnsCan1);
    stroke-width: 2.5;
    margin-right: 5px;

    @media (width <= 1200px) {
      --vSize: 3rem;
      width: var(--vSize);
      height: var(--vSize);
      margin-right: 10px;
    }
    @media (width <= 600px) {
      width: calc(var(--vSize) - 0.5rem);
      height: calc(var(--vSize) - 0.5rem);
    }
  }
}

</style>