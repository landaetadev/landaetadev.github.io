---
const { dataJsonExperiencia } = Astro.props;
import PuntoBarra from '../../PuntoBarra.astro';
---
<div class="cExperienciaCard">
  
  <PuntoBarra />

  <div class="cExperiencia">
    <p>{dataJsonExperiencia.jsonTime} - 
      {dataJsonExperiencia.jsonCompany} - 
      {dataJsonExperiencia.jsonCity}
    </p>
    <p>{dataJsonExperiencia.jsonJobTitle}</p>
    <p>{dataJsonExperiencia.jsonDescrip}</p>
  </div>

</div>

<style>

  .cExperienciaCard {
    max-width: 100%;
    display: flex;
    flex-direction: row;
    padding: 0 1rem;

    & .cExperiencia{
      width: 40rem;
      padding-bottom: 1.5rem;

      & p {
        font-family: var(--vRubikRegular);
        font-size: 22px;
        margin-left: 1rem;
        margin-bottom: .5rem;
        line-height: 2rem;

        @media ( width <= 600px ){
          font-size: 18px;
          line-height: 1.5rem;
        }
      }
    }
  }

</style>
