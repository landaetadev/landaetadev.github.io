---
import { Ancle } from '../../../pages/index.astro';
import CoverFotoDatos from './FotoDatos/CoverFotoDatos.astro';
import ArrowDown from './ArrowDown.astro';
---
<Ancle vIdAncle="idAncleHome" />
<div class="cCover">

  <CoverFotoDatos />
  <ArrowDown />

</div>

<style>

  .cCover {
    position: relative;
    background-image: image-set(
      url("/assets/images/backgrounds/002.avif") type("image/avif"),
      url("/assets/images/backgrounds/002.webp") type("image/webp"),
      url("/assets/images/backgrounds/002.jpg") type("image/jpeg")
    );
    background-repeat: no-repeat;
    background-attachment: fixed;
    background-position: center top;
    background-size: cover;
    margin-top: var(--vBarHeight);
    min-height: var(--vMinHeightClassScreen);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    border-bottom: var(--vHighBorder);
    border-image: var(--vBorderImage) 1;

    &::before {
      content: '';
      position: absolute;
      top: 0;
      width: 100%;
      height: 100%;
      background-color: rgb(0 0 0 / 0.6);
      pointer-events: none;
    }

  }

  @keyframes animArrow {
    0% {
      transform: translateY(0);
      stroke: var(--vBtnsCan1);
    }
    25% {
      stroke: var(--vBtnsCan2);
    }
    50% {
      transform: translateY(2rem);
      stroke: var(--vBtnsCan1);
    }
    75% {
      stroke: var(--vBtnsCan2);
    }
    100% {
      transform: translateY(0);
      stroke: var(--vBtnsCan1);
    }
  }

</style>