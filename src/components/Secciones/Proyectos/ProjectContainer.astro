---
const { dataJsonProyectos } = Astro.props;
import BtnCerrar from '../../Botones/btnCerrar.astro';
let letVideoFolder = "https://filedn.eu/lUfpa3BpLa45XCcSIQyWRHF/WWW/Portfolio/FilesProjects/"
---

<script >
  const btnCerrar = document.querySelectorAll('.cBtnClose');
  
  btnCerrar.forEach((btnCerrar) => {
    btnCerrar.addEventListener('click', () => {
      const vContainer = btnCerrar.closest('.cProjectContainer');
      funcPauseVideo();
      vContainer?.classList.remove('cShowContainer');
      document.body.classList.toggle("noScroll");
    });
  });

  function funcPauseVideo() {
      const cVideo = document.querySelectorAll<HTMLVideoElement>('.cVideo');
      cVideo.forEach(video => {
        video.pause();
        video.currentTime = 0;
      });
  }
  
</script>

<div class="cProjectContainer">
  <BtnCerrar />
  <div class="cProject">
    <h3 class="cTitle">{dataJsonProyectos.jsonTitle}</h3>
    <video controls preload="none" class="cVideo" >
      <source src={`${letVideoFolder}${dataJsonProyectos.jsonFileShow}.webm`} type="video/webm" />
      <source src={`${letVideoFolder}${dataJsonProyectos.jsonFileShow}.mp4`} type="video/mp4" />
    </video>
    <p class="cDescript">{dataJsonProyectos.jsonDescript}</p>
  </div>
  
</div>


<style>
  .cProjectContainer {
    background-image: var(--vUrlBackgroundImage);
    position: fixed;
    top: 0;
    left: 100%;
    width: 100%;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    z-index: 3;
    transition: all .5s ease-in-out;

    & .cProject{
      width: 100%;
      max-width: var(--vMaxWidthContent);
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;


      & .cTitle{
        font-family: var(--vRubikSemiBold);
        font-size: 28px;
        text-align: center;
        padding-bottom: 1rem;
      }

      & video{
        background-color: black;
        padding: 1.5rem 0;
        width: 1280px;
        max-width: 100%;
        max-height: 720px;
      }

      & .cDescript{
        max-width: 1000px;
        font-family: var(--vRubikRegular);
        font-size: 20px;
        padding: 1rem .5rem 0 .5rem;
        line-height: 1.5;
      }
    }

    
  }
  .cShowContainer {
    left: 0%;
    transition: all .5s ease-in-out;
  }
</style>