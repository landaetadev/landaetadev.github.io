---
import BtnOptMenu from '../Botones/btnOptMenu.astro';
---

<nav class="cMenuNav">
  <BtnOptMenu vIcoBtn="icoHome" vText="Inicio" vHref="#idAncleHome"/>
  <BtnOptMenu vIcoBtn="icoProyectos" vText="Proyectos" vHref="#idAncleProyectos"/>
  <BtnOptMenu vIcoBtn="icoHabilidades" vText="Habilidades" vHref="#idAncleHabilidades" />
  <BtnOptMenu vIcoBtn="icoExperiencia" vText="Experiencia" vHref="#idAncleExperiencia" />
  <BtnOptMenu vIcoBtn="icoFormacion" vText="Estudios" vHref="#idAncleFormacion" />
</nav>

<style>

  & .cMenuNav {
    display: flex;
    flex-direction: row;
    gap: 1rem;
    @media (width <= 1200px) {
      background-color: transparent;
      backdrop-filter: blur(50px);
      margin-top: var(--vBarHeight);
      padding-top: 1rem;
      width: 100%;
      height: 100vh;
      visibility: visible;
      flex-direction: column;
      align-items: center;
      position: fixed;
      top: 0;
      left: 100%;
      transition: all .3s ease;
      
      &.activo {
        left: 0;
      }
    }
  }

</style>